
#include <stdio.h>
int fibo(int n){
    int a=0,b=1,temp;
    for(int i=1;i<=n;i++){
        printf(" %d  ",a);
        temp=a+b;
        a=b;
        b=temp;
    }
}
int main(){
    int n,temp;
    printf("Enter number of terms: ");
    scanf("%d",&n);
    printf("Fibonacci series: ");
    fibo(n);
    return 0;
}
