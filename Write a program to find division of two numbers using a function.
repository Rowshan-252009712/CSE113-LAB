#include <stdio.h>
float divide(float x,float y)
{   if(y==0){
      printf("Division by zero is not possible.\n");
     }
else{
    return x/y;
    }
}
int main(){
    float a, b, result;
    printf("Enter Dividend: ");
    scanf("%f",&a);
    printf("Enter Divisor:  ");
    scanf("%f",&b);

    result = divide(a,b);
    printf("Division= %.2f",result);
    return 0;
}
