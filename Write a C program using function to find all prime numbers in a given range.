#include<stdio.h>
int prime(int n){
    if(n<=1){
        return 0;
    }
    for(int i=2;i*i<=n;i++){
        if(n%i==0){
            return 0;
        }
    }
    return 1;
}
int main(){
    int x,y;
    printf("Enter start of range\t: ");
    scanf("%d",&x);
    printf("Enter end of range\t: ");
    scanf("%d",&y);
    printf("Prime numbers from %d to %d:\n",x,y);
    for(int i=x;i<=y;i++){
        if(prime(i)){
            printf("%d\n",i);
        }
    }
return 0;
}
